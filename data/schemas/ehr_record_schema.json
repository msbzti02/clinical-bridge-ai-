{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "ehr_record_schema.json",
  "type": "object",
  "required": ["record_id", "patient_id", "record_type", "content", "timestamp"],
  "properties": {
    "record_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this EHR record"
    },
    "patient_id": {
      "type": "string",
      "format": "uuid",
      "description": "FK to patient"
    },
    "record_type": {
      "type": "string",
      "enum": ["problem_list", "medication", "lab_result", "visit_note", "allergy"]
    },
    "content": {
      "type": ["string", "object"],
      "description": "Free text for visit_note; structured dict for others"
    },
    "icd10_codes": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Z][0-9]{2}(\\.[0-9A-Z]{1,4})?$"},
      "description": "Valid ICD-10 codes; only for problem_list records"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source_facility": {
      "type": "string"
    }
  }
}
